<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Menu?>
<?import javafx.scene.control.MenuBar?>
<?import javafx.scene.control.MenuItem?>

<MenuBar prefWidth="900.0" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.taskmanager.controller.AdminMenuController">
  <menus>
      <Menu mnemonicParsing="false" text="Task">
         <items>
            <MenuItem mnemonicParsing="false" onAction="#showTaskSearchScreen" text="Search and delete" />
            <MenuItem mnemonicParsing="false" onAction="#showTaskAddScreen" text="Add new" />
            <MenuItem mnemonicParsing="false" onAction="#showTaskUpdateScreen" text="Update" />
         </items>
      </Menu>
    <Menu mnemonicParsing="false" text="Postition">
      <items>
            <MenuItem mnemonicParsing="false" onAction="#showPositionSearchScreen" text="Search and delete" />
            <MenuItem mnemonicParsing="false" onAction="#showPositionAddScreen" text="Add new" />
      </items>
    </Menu>
    <Menu mnemonicParsing="false" text="Employee">
      <items>
        <MenuItem mnemonicParsing="false" onAction="#showEmployeeSearchScreen" text="Search and delete" />
            <MenuItem mnemonicParsing="false" onAction="#showEmployeeAddScreen" text="Add new" />
            <MenuItem mnemonicParsing="false" onAction="#showEmployeeUpdateScreen" text="Update" />
      </items>
    </Menu>
      <Menu mnemonicParsing="false" text="Changes">
         <items>
            <MenuItem mnemonicParsing="false" onAction="#showChangeLogScreen" text="Change logs" />
         </items>
      </Menu>
      <Menu mnemonicParsing="false" text="Log out">
         <items>
            <MenuItem mnemonicParsing="false" onAction="#logOut" text="Log out" />
         </items>
      </Menu>
  </menus>
</MenuBar>
